digraph control_flow {
	graph [bgcolor=transparent margin=0.2 nodesep=0.5 pad=0.1 rankdir=TB ranksep=0.7 splines=ortho]
	node [color="#2c3e50" fillcolor="#e8f4f8" fontname=Helvetica fontsize=10 margin="0.15,0.1" shape=box style="rounded,filled"]
	edge [arrowhead=vee arrowsize=0.8 color="#2c3e50" fontname=Helvetica fontsize=9]
	start [label="Start:
24 Waypoints" fillcolor="#90EE90" shape=ellipse]
	spline [label="Generate Cubic
Spline Coefficients"]
	loop [label="Real-Time Loop
(5ms cycle)" shape=box style="rounded,filled,bold"]
	read_enc [label="Read Encoders
(5 motors)" fillcolor="#fffacd"]
	calc_err [label="Calculate Error:
e = desired - actual"]
	pi1 [label="Motor 1-3:
PI Control
(linear axes)"]
	pid45 [label="Motor 4-5:
PID Control
(rotation/gripper)"]
	pwm [label="Output PWM
Commands"]
	check [label="Waypoint
reached?" fillcolor="#ffcccc" shape=diamond]
	next [label="Next Waypoint"]
	log [label="Log Telemetry
to CSV"]
	sleep [label="Sleep 5ms"]
	done [label=Done fillcolor="#90EE90" shape=ellipse]
	start -> spline
	spline -> loop
	loop -> read_enc
	read_enc -> calc_err
	calc_err -> pi1
	calc_err -> pid45
	pi1 -> pwm
	pid45 -> pwm
	pwm -> log
	log -> check
	check -> next [label=No]
	next -> loop [style=dashed]
	check -> done [label=Yes]
}
